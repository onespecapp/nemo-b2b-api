// Nemo B2B API - Prisma Schema
// AI Receptionist for trades businesses

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// BUSINESS - The company using Nemo B2B
// ============================================
model Business {
  id    String  @id @default(cuid())
  name  String
  phone String?
  email String?

  // Supabase auth user who owns this business
  owner_id String

  // Business category (determines call templates)
  category BusinessCategory @default(OTHER)

  // Timezone
  timezone String @default("America/Los_Angeles")

  // AI Voice settings
  voice_preference String @default("Aoede") // Puck, Charon, Kore, Fenrir, Aoede

  // Telnyx phone line
  telnyx_phone_number  String? @unique
  telnyx_connection_id String?

  // AI Receptionist settings
  receptionist_enabled      Boolean @default(false)
  receptionist_greeting     String?
  receptionist_instructions String?
  business_hours            Json?
  services                  Json?
  faqs                      Json?
  transfer_phone            String?

  // Booking settings
  booking_enabled              Boolean @default(false)
  default_appointment_duration Int     @default(60)
  booking_advance_days         Int     @default(14)

  // Subscription
  subscription_tier   SubscriptionTier   @default(FREE)
  subscription_status SubscriptionStatus @default(ACTIVE)

  // Relations
  customers    Customer[]
  appointments Appointment[]
  call_logs    CallLog[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("b2b_businesses")
}

// ============================================
// CUSTOMER - People the business calls
// ============================================
model Customer {
  id    String  @id @default(cuid())
  name  String
  phone String
  email String?
  notes String?

  // Business relation
  business_id String
  business    Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  // Relations
  appointments Appointment[]
  call_logs    CallLog[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("b2b_customers")
}

// ============================================
// APPOINTMENT - Scheduled events to remind about
// ============================================
model Appointment {
  id           String   @id @default(cuid())
  title        String
  description  String?
  scheduled_at DateTime
  duration_min Int      @default(30)

  // Reminder settings
  reminder_enabled        Boolean @default(true)
  reminder_minutes_before Int     @default(30) // Minutes before to call

  // Status
  status AppointmentStatus @default(SCHEDULED)

  // Relations
  business_id String
  business    Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  call_logs CallLog[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("b2b_appointments")
}

// ============================================
// CALL LOG - Record of AI calls made
// ============================================
model CallLog {
  id String @id @default(cuid())

  // Call details
  call_type    CallType
  call_outcome CallOutcome?
  duration_sec Int?

  // LiveKit/SIP details
  room_name   String?
  sip_call_id String?

  // Caller info
  to_number   String?
  from_number String?
  caller_name String?

  // Transcript
  transcript Json?
  summary    String?

  // Relations
  business_id String
  business    Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  customer_id String?
  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)

  appointment_id String?
  appointment    Appointment? @relation(fields: [appointment_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())

  @@map("b2b_call_logs")
}

// ============================================
// MESSAGE - Messages taken by AI receptionist
// ============================================
model Message {
  id           String  @id @default(cuid())
  business_id  String
  call_log_id  String?
  caller_name  String?
  caller_phone String?
  message      String
  reason       String?
  urgency      String  @default("normal")
  read         Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("b2b_messages")
}

// ============================================
// ENUMS
// ============================================

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  RESCHEDULED
  CANCELED
  COMPLETED
  NO_SHOW
}

enum CallType {
  REMINDER // Scheduled appointment reminder
  TEST // Test call from dashboard
  INBOUND // Inbound call handled by AI receptionist
}

enum CallOutcome {
  ANSWERED
  NO_ANSWER
  VOICEMAIL
  BUSY
  FAILED
  CONFIRMED
  RESCHEDULED
  CANCELED
  BOOKED // Customer booked a new appointment
  MESSAGE_TAKEN // Message taken for the business
  TRANSFERRED // Call transferred to business owner
  DECLINED // Customer declined the offer
}

enum BusinessCategory {
  BARBERSHOP
  SALON
  DENTAL
  MEDICAL
  AUTO_REPAIR
  PET_GROOMING
  SPA
  FITNESS
  TUTORING
  PLUMBING
  HVAC
  ELECTRICAL
  GENERAL_CONTRACTOR
  LANDSCAPING
  ROOFING
  PAINTING
  OTHER
}
